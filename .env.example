NODE_ENV=production
PORT=8000

# MongoDB Atlas or hosted MongoDB connection string
MONGODB_URI=mongodb+srv://

# Comma-separated frontend URLs (https, no trailing slash)
CLIENT_URL=https://car-rental-frontend-rust.vercel.app/

# Optional: allow any *.vercel.app preview deployment
CORS_ALLOW_VERCEL=true

JWT_SECRET=your-long-random-secret
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10
MAX_FILE_SIZE=5242880
